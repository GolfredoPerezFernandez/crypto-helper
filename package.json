{
  "name": "crypto-helper",
  "description": "Crypto Helper — Qwik dashboard, Turso, market sync, and alerts",
  "engines": {
    "node": ">=20.19.0"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "deploy": "git add . && git commit -m \"ejemplo\" && git push origin && wrangler pages publish ./dist",
    "dev": "vite --mode ssr",
    "dev.custom": "CUSTOM_CONFIG=true vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "drizzle:check": "drizzle-kit check",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:pull": "drizzle-kit pull",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio",
    "drizzle:up": "drizzle-kit up",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "postinstall": "drizzle-kit generate",
    "preview": "qwik build preview && vite preview",
    "serve": "node server/entry.express",
    "webhook:fixture": "node scripts/post-moralis-webhook-fixture.mjs",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@qwik-ui/headless": "^0.7.4",
    "@qwikdev/pwa": "^0.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.7.2",
    "@types/d3": "^7.4.3",
    "@types/eslint": "^8.56.3",
    "@types/express": "^4.17.19",
    "@types/express-rate-limit": "^6.0.2",
    "@types/leaflet": "^1.9.6",
    "@types/node": "^20.19.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^11.8.1",
    "compression": "^1.7.4",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.30.3",
    "drizzle-orm": "^0.39.0",
    "eslint": "^8.57.0",
    "eslint-plugin-qwik": "^1.19.2",
    "fast-glob": "^3.3.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "undici": "^5.28.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^3.114.17"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.3",
    "@libsql/client": "^0.15.2",
    "@qwikest/icons": "^0.0.13",
    "@storacha/client": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/qrcode": "^1.5.5",
    "@uniswap/sdk-core": "^7.9.0",
    "@uniswap/v3-sdk": "^3.26.0",
    "chart.js": "^4.5.0",
    "country-flag-icons": "^1.5.18",
    "d3": "^7.9.0",
    "ethers": "^6.15.0",
    "express": "4.20.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "langchain": "^1.3.1",
    "leaflet": "1.9.4",
    "moralis": "^2.27.2",
    "node-cron": "^3.0.3",
    "qrcode": "^1.5.4",
    "qwik-speak": "^0.24.0",
    "viem": "^2.33.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
