# =============================================================================
# Crypto Helper — environment variables
# Copy to `.env` or `.env.local`. Do not commit real secrets.
#
# Qwik / Vite rules (see https://qwik.dev/docs/integrations/environment-variables/)
# -----------------------------------------------------------------------------
# • PUBLIC_*     — Inlined at build time; exposed to the browser. Never put API
#                  keys, Moralis, CMC, DB tokens, or webhooks secrets here.
# • No PUBLIC_   — Server-only. Safe for secrets. In this repo:
#                    - Express loads `dotenv/config` (entry.express.tsx); SSR loads it too
#                      (entry.ssr.tsx), so `npm run dev` route handlers see `process.env.*`.
#                    - In Qwik routeLoaders / onRequest, prefer
#                      `requestEvent.env.get('NAME')` when available; it reads the
#                      same deployment env on supported platforms.
# • Avoid `process.env` inside Qwik components that may run on the client;
#                  use `import.meta.env.PUBLIC_*` there instead.
# =============================================================================

# --- Server & Qwik City (production URL / adapter) ---------------------------
PORT=3000
NODE_ENV=development

# Public origin of this deployment (scheme + host, no trailing slash).
# Qwik City Node adapter uses ORIGIN for request origin checks; Docker sets it.
# Example: https://crypto-ghost.fly.dev
ORIGIN=http://localhost:3000

# Canonical site URL for docs, Moralis Streams, and reverse proxies.
# Configure your Moralis webhook URLs as: {PUBLIC_APP_URL}/api/webhook/moralis/whales
# and :.../traders
PUBLIC_APP_URL=http://localhost:3000

# Default locale for server-generated deep links (live signal push). Should match your primary [locale] segment.
PUBLIC_DEFAULT_LOCALE=en-us

# Web Push (VAPID) — PWA notifications for live signals (whale / smart money / USDT smart).
# Generate: npx web-push generate-vapid-keys
# PUBLIC_* is bundled to the client (safe: public key only). PRIVATE_* is server-only.
PUBLIC_VAPID_KEY=
PRIVATE_VAPID_KEY=
# Contact embedded in VAPID JWT (mailto: or https: URL).
VAPID_CONTACT_EMAIL=mailto:you@example.com

# =============================================================================
# Database — Turso / libSQL (main app: users, market cache, signals, sync_runs)
# Qwik doc: https://qwik.dev/docs/integrations/turso/ — same var names.
#
# Required: remote URL (libsql://… or https://….turso.io) + auth token from Turso CLI.
# Local file: only if you also set ALLOW_LOCAL_TURSO_FILE=1 (off by default).
#
# New remote DB: apply migrations once from repo root (loads .env via drizzle.config):
#   npm run drizzle:migrate
# =============================================================================
PRIVATE_TURSO_DATABASE_URL=libsql://your-db-org.turso.io
PRIVATE_TURSO_AUTH_TOKEN=
# ALLOW_LOCAL_TURSO_FILE=1

# Optional: separate libSQL for marketplace chat. If unset, chat uses PRIVATE_TURSO_DATABASE_URL
# (+ PRIVATE_TURSO_AUTH_TOKEN). Local dev without Turso falls back to file:chat.db in code.
# PRIVATE_CHAT_DB_URL=
# PRIVATE_CHAT_DB_AUTH_TOKEN=

# =============================================================================
# Crypto Helper — server API keys
# =============================================================================

# Required for webhooks, wallet/NFT/ERC20 on server, SSE pipeline enrichment.
# Alias supported: MORALIS (legacy name).
MORALIS_API_KEY=
# MORALIS=
#
# Moralis Streams (live whale / trader SSE):
# • Run the app with Express (`yarn build.server` then `yarn serve`), not Vite-only `yarn dev`.
# • Two streams → webhook URLs: {PUBLIC_APP_URL}/api/webhook/moralis/whales and .../traders
# • Include token transfers + logs; each log should populate `triggered_by` (Moralis does this for monitored wallets).
# • Send pending/unconfirmed payloads: code ignores `body.confirmed === true` (no insert, no SSE).
# • Optional: include `abi` (enables Moralis.Streams.parsedLogs); alerts work from logs + erc20Transfers alone.
# • Local test: node scripts/post-moralis-webhook-fixture.mjs http://localhost:3000 whales
#
# Optional — enrich CMC token snapshots with Moralis Token API (Pro+; extra CUs per token):
# MORALIS_SYNC_TOKEN_INSIGHTS=1   → token score + pairs (and metadata already on)
# MORALIS_SYNC_TOKEN_SCORE_HISTORICAL=1   → adds score timeseries (~150 CUs per token)
# MORALIS_SYNC_TOKEN_SWAPS=1   → DEX swaps list per token (~50 CUs per token)
# MORALIS_SYNC_TOKEN_ANALYTICS=1   → GET /tokens/{address}/analytics (~80 CUs per token)
# MORALIS_SYNC_TOKEN_TOP_LOSERS=1   → GET /erc20/{token}/top-losers (parallel with core batch)
# MORALIS_SYNC_TOKEN_SNIPERS=1   → GET /pairs/{firstPair}/snipers (requires INSIGHTS=1 for pairs)
# MORALIS_SYNC_TOKEN_SNIPERS_BLOCKS=3   → optional blocksAfterCreation (0–1000)
#
# Wallet snapshots (daily auxiliary sync, per watched wallet):
# MORALIS_SYNC_WALLET_DEFI=1   → defi summary + positions on base + eth
# MORALIS_SYNC_WALLET_PROFITABILITY_DETAIL=1   → full GET .../profitability (vs summary already on)
# MORALIS_SYNC_WALLET_APPROVALS=1   → GET .../approvals base + eth
#
# Global Moralis rows in api_global_snapshots (once per auxiliary sync):
# MORALIS_SYNC_GLOBAL_TOKEN_CATEGORIES=1   → GET /tokens/categories
# MORALIS_SYNC_GLOBAL_DISCOVERY_TOP_LOSERS=1   → chain-wide top losers (high CU; use sparingly)
# MORALIS_SYNC_GLOBAL_DISCOVERY_CHAIN=eth
# MORALIS_SYNC_GLOBAL_DISCOVERY_TOP_LOSERS_LIMIT=40
# MORALIS_SYNC_GLOBAL_LATEST_BLOCKS=1   → latest block for base + eth
#
# Solana (Moralis): uses the same MORALIS_API_KEY as EVM. Optional vars belong in your real `.env`:
#   MORALIS_SOLANA_NETWORK=mainnet|devnet
#   MORALIS_SYNC_WALLET_SOLANA=1   (set 0|false to skip Solana wallet snapshots in the daily sync)
# HTTP paths and `/api/crypto/moralis/solana/...` proxies are described in the dashboard (Solana pages).

# CoinMarketCap — daily market sync (categories, prices, slugs).
# After setting this, run once: POST /api/crypto/sync/run (Qwik dev: OK if CRON_SECRET is empty).
CMC_API_KEY=

# Per category: max rows from Turso not in this run’s CMC listing batch to refresh via quotes/latest (0 = off). Default 800.
# Spreads work across runs if you have many historical tokens (oldest updatedAt first).
# CMC_STALE_REFRESH_PER_CATEGORY=800

# OpenAI — Crypto Helper DB insight (LangChain SQL agent, admin-only route). Optional: model override (default gpt-4o-mini).
# OPENAI_DB_CHAT_MODEL=gpt-4o-mini

# Bearer for POST /api/internal/daily-sync (Express) and POST /api/crypto/sync/run when set.
# In production, set a strong secret. Local dev: can stay empty to allow sync/run without header.
CRON_SECRET=

# node-cron expression (default 03:00 UTC daily). Express (`yarn serve`) registers this on boot.
# Fly.io: set `http_service.auto_stop_machines = false` (or similar) so the process stays up; otherwise
# Machines that stop idle never run the scheduler until the next HTTP wake-up.
SYNC_CRON=0 3 * * *

# Ethereum JSON-RPC for optional USDT fresh-wallet watcher + smart SSE alerts.
# If unset, watcher is disabled (see server logs).
ETHEREUM_RPC_URL=

# Minimum milliseconds between smart alerts (default 600000 = 10 min).
SMART_ALERT_INTERVAL_MS=600000

# =============================================================================
# Server encryption (managed wallet / sensitive payloads)
# Required in production when encryption helpers are used.
# =============================================================================
ENCRYPTION_KEY=

# =============================================================================
# Marketplace / chain — PUBLIC_* (bundled; visible in browser)
# =============================================================================
PUBLIC_CHAIN_ID=8453
# Base / app RPC (client + server where applicable).
PUBLIC_RPC_URL=
PUBLIC_FALLBACK_RPC_URL=
# Pro upgrade: dirección de tesorería EVM (opcional; hay default en código). Contratos USDT por red: src/constants/pro-networks.ts
PUBLIC_PRO_PAYMENT_RECIPIENT=0xf6657f7019e481204d26882d6b1bed1da1541896
# Opcional: JSON-RPC solo si falla el RPC público al verificar un pago Pro (ej. PRO_VERIFY_RPC_8453=…).
PUBLIC_REQUIRED_CONFIRMATIONS=1
PUBLIC_TX_TIMEOUT=120000

# KNRT marketplace contracts
PUBLIC_NFT_ADDRESS=
PUBLIC_SALE_MARKET_ADDRESS=
PUBLIC_RENTAL_MARKET_ADDRESS=
PUBLIC_POWER_MARKET_ADDRESS=
PUBLIC_KNRT_TOKEN_ADDRESS=

# Property / legacy real-estate deployment (blockchain.ts)
PUBLIC_REALESTATE_MARKETPLACE_ADDRESS=
PUBLIC_PROPERTY_NFT_ADDRESS=
PUBLIC_POWER_TRANSFER_MARKETPLACE_ADDRESS=
PUBLIC_PROPERTY_RENTAL_MANAGER_ADDRESS=

# Aliases used by mint / property flows
PUBLIC_NFT_CONTRACT_ADDRESS=
PUBLIC_ERC20_FACTORY_ADDRESS=
# Hex bytecode string if deploy-ERC20-from-bytecode path is used
PUBLIC_ERC20_BYTECODE=

PUBLIC_DEFAULT_GAS_LIMIT=500000
PUBLIC_DEFAULT_GAS_PRICE=1000000000

# IPFS gateway hostname for NFT metadata URLs (client + server)
PUBLIC_STORACHA_GATEWAY_HOST=storacha.link

# Optional: only for client-side Moralis calls (e.g. profile). Prefer server
# routes when possible; never use the same unrestricted key as production server
# unless you accept exposure.
PUBLIC_MORALIS_API_KEY=

# =============================================================================
# NFT upload API (server-only — NOT PUBLIC_*)
# Route: POST /api/nft/upload
# =============================================================================
STORACHA_KEY=
STORACHA_PROOF=

# =============================================================================
# Optional: Qwik PWA / local experiments
# =============================================================================
# CUSTOM_CONFIG=true

# =============================================================================
# Reference — read in code but usually set by the platform
# -----------------------------------------------------------------------------
# BASE_URL, MODE, DEV, PROD, SSR — provided by Vite/Qwik (import.meta.env)
# VERCEL_URL, CF_PAGES_URL — hosting; some templates use these for ORIGIN
# =============================================================================
