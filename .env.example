# Copiar a `.env` y rellenar. La documentación completa de opciones está en `.env` (local).
# No subir `.env` al repositorio.

NODE_ENV=development
PORT=3000
ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

PRIVATE_TURSO_DATABASE_URL=
PRIVATE_TURSO_AUTH_TOKEN=

MORALIS_API_KEY=
NANSEN_API_KEY=
CMC_API_KEY=

CRON_SECRET=
SYNC_CRON=0 3 * * *

ETHEREUM_RPC_URL=

SMART_ALERT_INTERVAL_MS=600000
USDT_WATCHER_CONFIRMATIONS=2
USDT_WATCHER_BLOCK_CHUNK=2

ENCRYPTION_KEY=

PUBLIC_DEFAULT_LOCALE=en-us
PUBLIC_VAPID_KEY=
PRIVATE_VAPID_KEY=
VAPID_CONTACT_EMAIL=

OPENAI_API_KEY=

PUBLIC_CHAIN_ID=8453
PUBLIC_RPC_URL=
PUBLIC_REQUIRED_CONFIRMATIONS=1
PUBLIC_TX_TIMEOUT=120000

WHALE_ALERT_API_KEY=
WHALE_ALERT_SYNC=1
